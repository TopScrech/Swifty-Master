          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Діалог підтвердження показує список варіантів, зазвичай для руйнівних або другорядних дій"
          }
        }
      }
    },
    "A container that enables navigation between views using a navigation bar (deprecated in iOS 16 in favor of NavigationStack)" : {
      "comment" : "A description of a view that enables navigation between views using a navigation bar, with a note that this feature has been deprecated in iOS 16 in favor of `NavigationStack`.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Container, der die Navigation zwischen Ansichten über eine Navigationsleiste ermöglicht (seit iOS 16 zugunsten von NavigationStack veraltet)"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un conteneur qui permet de naviguer entre les vues à l’aide d’une barre de navigation (obsolète depuis iOS 16 au profit de NavigationStack)"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "एक container जो navigation bar का उपयोग करके views के बीच navigation सक्षम करता है (iOS 16 में NavigationStack के पक्ष में deprecated)"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Een container die navigatie tussen weergaven mogelijk maakt met een navigatiebalk (verouderd in iOS 16 ten gunste van NavigationStack)"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Контейнер, который обеспечивает навигацию между представлениями с помощью панели навигации (устарел в iOS 16 в пользу NavigationStack)"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Navigation bar kullanarak view’lar arasında navigation sağlayan bir container (iOS 16’da NavigationStack lehine deprecated oldu)"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Контейнер, що забезпечує навігацію між view за допомогою навігаційної панелі (застарів в iOS 16 на користь NavigationStack)"
          }
        }
      }
    },
    "A Link opens a specified URL in the user’s default browser or associated app" : {
      "comment" : "A description of how a link can open a URL in a user's default browser or app.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Link öffnet eine angegebene URL im Standardbrowser des Benutzers oder in der zugehörigen App"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un Link ouvre une URL indiquée dans le navigateur par défaut de l’utilisateur ou dans l’app associée"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Link किसी दिए गए URL को user के default browser या संबंधित app में खोलता है"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Een Link opent een opgegeven URL in de standaardbrowser van de gebruiker of in de bijbehorende app"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Link открывает указанный URL в браузере пользователя по умолчанию или в связанном приложении"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Link, belirtilen URL’yi kullanıcının default browser’ında veya ilişkili app içinde açar"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
