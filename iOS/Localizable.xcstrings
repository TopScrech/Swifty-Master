        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un ShareLink permet de partager une URL, du texte ou d’autres éléments transférables avec la feuille de partage du système"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ShareLink लोगों को system share sheet का उपयोग करके URL, text या अन्य transferable items share करने देता है"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Met ShareLink kunnen mensen een URL, tekst of andere overdraagbare items delen via het systeemdeelvenster"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ShareLink позволяет людям делиться URL, текстом и другими передаваемыми элементами через системное меню шаринга"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ShareLink, kullanıcıların sistem share sheet ile URL, text veya diğer transferable items paylaşmasını sağlar"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ShareLink дає змогу ділитися URL, текстом або іншими transferable items через системний sheet поширення"
          }
        }
      }
    },
    "A sheet presents a modal view over the current screen, often used for settings or secondary content" : {
