    "@Environment(\\.horizontalSizeClass) lets you detect the available horizontal space class so you can adapt your layout for compact or regular widths" : {
      "localizations" : {
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Met @Environment(\\.horizontalSizeClass) kun je de beschikbare horizontale size class detecteren, zodat je je layout kunt aanpassen voor compacte of reguliere breedtes"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "С помощью @Environment(\\.horizontalSizeClass) можно определить доступный горизонтальный size class и адаптировать интерфейс под компактную или обычную ширину"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mit @Environment(\\.horizontalSizeClass) kannst du die verfügbare horizontale Größenklasse erkennen und dein Layout für kompakte oder reguläre Breiten anpassen"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "@Environment(\\.horizontalSizeClass) permet de détecter la classe de taille horizontale disponible afin d’adapter votre mise en page aux largeurs compactes ou régulières"
