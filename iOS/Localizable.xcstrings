    "A confirmation dialog presents a list of choices, typically for destructive or secondary actions" : {
      "comment" : "A description of what a confirmation dialog is.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Bestätigungsdialog zeigt eine Liste von Optionen, meist für destruktive oder sekundäre Aktionen"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une boîte de dialogue de confirmation présente une liste de choix, généralement pour des actions destructives ou secondaires"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confirmation dialog विकल्पों की सूची दिखाता है, आमतौर पर destructive या secondary actions के लिए"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Een bevestigingsdialoog toont een lijst met keuzes, meestal voor destructieve of secundaire acties"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Диалог подтверждения показывает список вариантов, обычно для разрушительных или второстепенных действий"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
